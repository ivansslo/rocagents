# ─── Auto-select model per provider ──────────────────────────────────────────
_default_model_for() {
  case "$1" in
    openai|oai)   echo "gpt-4o" ;;
    openrouter|or) echo "openai/gpt-4o" ;;
    gemini)       echo "gemini-1.5-flash" ;;
    groq)         echo "llama-3.3-70b-versatile" ;;
    oci|ollama)   echo "rocspace-initial" ;;
    gateway)      echo "llama-3.3-70b-versatile" ;;
    ais|aisdev|newcr|ais-dev) echo "gemini-1.5-flash" ;;
    cf|cfai)      echo "@cf/meta/llama-3.3-70b-instruct-fp8-fast" ;;
    best|auto|all) echo "auto" ;;
    *)            echo "llama-3.3-70b-versatile" ;;
  esac
}

_provider_ready() {
  case "$1" in
    openai|oai)   [ -n "$OPENAI_KEY" ] ;;
    openrouter|or) [ -n "$OR_KEY" ] ;;
    gemini)        [ -n "$GEMINI_KEY" ] ;;
    groq)          [ -n "$GROQ_KEY" ] ;;
    oci|ollama)    [ -n "$OCI_MODEL_ENDPOINT" ] ;;
    gateway)       [ -n "$TOKEN" ] ;;
    cloudrun)      [ -n "$TOKEN" ] ;;
    ais|aisdev|newcr|ais-dev) [ -n "$TOKEN" ] ;;
    cf|cfai)       [ -n "$TOKEN" ] || [ -n "$CF_AI_TOKEN" ] ;;
    *)             return 1 ;;
  esac
}

_best_ai_runtime() {
  # Ranking: Groq (fast) -> AIS-DEV (high thinking) -> OpenAI -> OpenRouter (smart)
  #          -> Gemini -> Gateway -> CloudRun -> CF
  # Override with PROVIDER=<name> MODEL=<model> when a specific runtime is desired.
  if _provider_ready groq; then
    echo "groq|$(_default_model_for groq)"; return
  fi
  if _provider_ready ais; then
    echo "ais|$(_default_model_for ais)"; return
  fi
  if _provider_ready openai; then
    echo "openai|$(_default_model_for openai)"; return
  fi
  if _provider_ready openrouter; then
    echo "openrouter|$(_default_model_for openrouter)"; return
  fi
  if _provider_ready gemini; then
    echo "gemini|$(_default_model_for gemini)"; return
  fi
  if _provider_ready gateway; then
    echo "gateway|$(_default_model_for gateway)"; return
  fi
  if _provider_ready cloudrun; then
    echo "cloudrun|$(_default_model_for cloudrun)"; return
  fi
  if _provider_ready cfai; then
    echo "cfai|$(_default_model_for cfai)"; return
  fi
  echo "groq|$(_default_model_for groq)"
}

_resolve_ai_runtime() {
  local provider="${1:-${PROVIDER:-best}}" model="${2:-${MODEL:-}}" sel
  case "$provider" in
    best|auto|all|"")
      sel="$(_best_ai_runtime)"
      provider="${sel%%|*}"
      model="${sel#*|}"
      ;;
    *)
      [ -z "$model" ] || [ "$model" = "auto" ] && model="$(_default_model_for "$provider")"
      ;;
  esac
  echo "$provider|$model"
}

