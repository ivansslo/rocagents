          echo "$h" | grep -o '"services":\[[^]]*\]' | tr ',' '\n' | grep -o '"[a-z-]*"' | tr -d '"' | sed "s/^/    ${C}▸${N} /"
        fi
        echo ""
      fi
      echo -e "  ${BOLD}🧠 Antigravity IDE${N} ${D}(label: $AI_STUDIO_AG_LABEL)${N}:"
      _vm_probe "Node HP (web :$AG_VNC_PORT)"     "http://localhost:$AG_VNC_PORT/" || true
      _vm_probe "Node VM (noVNC :$AG_NOVNC_PORT)" "http://$VM_IP:$AG_NOVNC_PORT/vnc.html" || true
      echo ""
      echo -e "  ${D}Aksi cepat: hermes vm console | wvc | kuma | monitor | novnc | ssh | tailscale${N}"
      ;;
    console|open) _vm_open "$VM_CONSOLE_URL" ;;
    wvc|webvirtcloud) _vm_open "$WVC_URL" ;;
    kuma|uptime)  _vm_open "$VM_KUMA_URL" ;;
    monitor)      _vm_open "$VM_MONITOR_URL" ;;
    novnc|vnc)    _vm_open "$VM_NOVNC_URL" ;;
    studio|aistudio)
      _vm_open "$AI_STUDIO_APP"
      echo -e "  ${D}(subdomain ${C}$AI_STUDIO_WVC_LABEL${D} milik Google — tidak bisa di-klaim; panel VM ada di Hermes Dashboard + $VM_CONSOLE_URL)${N}"
      ;;
    ssh)
      echo -e "  ${BOLD}ssh $VM_SSH_USER@$VM_IP${N}  ${D}(atau via tailnet: ssh $VM_SSH_USER@$VM_TAILSCALE_IP)${N}"
      echo -e "  ${D}Port 22 open · gunakan key OCI Anda (lihat OCI_* di SECRETS-MASTER)${N}"
      ;;
    tailscale|ts)
      echo -e "  ${W}Tailnet IP VM:${N} $VM_TAILSCALE_IP"
      if command -v tailscale &>/dev/null; then
        tailscale status 2>/dev/null | head -10 || warn "tailscaled belum jalan — lihat scripts/tailscale-userspace.sh di repo rocspace"
      else
        warn "tailscale CLI tidak ditemukan — lihat scripts/tailscale-userspace.sh di repo rocspace"
      fi
      ;;
    tailscale-off|ts-off)
      header
      echo -e "${BOLD}🔴 Nonaktifkan Tailscale di OCI VM...${N}\n"
      echo -e "  Host Target: ${C}${VM_SSH_USER:-ubuntu}@${VM_IP:-161.118.253.28}${N}\n"
      info "Mengirim perintah penghentian Tailscale via SSH..."
      local ssh_opts="-o StrictHostKeyChecking=no -o ConnectTimeout=10"
      [ -n "${OCI_SSH_KEY:-}" ] && [ -r "$OCI_SSH_KEY" ] && ssh_opts="$ssh_opts -i $OCI_SSH_KEY"
      ssh $ssh_opts "${VM_SSH_USER:-ubuntu}@${VM_IP:-161.118.253.28}" \
        "sudo tailscale down 2>/dev/null || true; sudo systemctl stop tailscaled 2>/dev/null || true; sudo systemctl disable tailscaled 2>/dev/null || true; echo '✅ Tailscale berhasil dinonaktifkan di VM OCI.'"
      ;;
    services|svc)
      curl -sS -m 8 "$VM_HEALTH_URL" 2>/dev/null | python3 -c 'import sys,json; d=json.load(sys.stdin); print(json.dumps(d,indent=2))' 2>/dev/null \
        || curl -sS -m 8 "$VM_HEALTH_URL" 2>/dev/null
      ;;
    *)
      err "Unknown vm subcommand: $sub"
      echo -e "  ${D}status|console|wvc|kuma|monitor|novnc|studio|ssh|tailscale|services${N}"
      return 1 ;;
  esac
}

# ═════════════════════════════════════════════════════════════════════════════
#  OCI PRIVATE MODEL — ROCSPACE-INITIAL
# ═════════════════════════════════════════════════════════════════════════════
cmd_oci() {
  local sub="${1:-status}"; shift 2>/dev/null || true
  local action="${1:-status}"; [ "$sub" = "model" ] && { shift 2>/dev/null || true; action="${1:-status}"; }
  case "$sub:$action" in
    status:*|model:status)
      header
      echo -e "${BOLD}☁️  OCI private model${N}\n"
      echo -e "  ${W}Model:${N}      $OCI_MODEL_NAME"
      echo -e "  ${W}Base:${N}       $OCI_MODEL_BASE"
      echo -e "  ${W}Access:${N}     Tailscale private only"
      echo -e "  ${W}Endpoint:${N}   $OCI_MODEL_TAILSCALE_URL ${D}(only from tailnet)${N}"
      if command -v curl >/dev/null 2>&1; then
        local code; code=$(curl -sS -m 5 -o /dev/null -w '%{http_code}' "$OCI_MODEL_TAILSCALE_URL/api/tags" 2>/dev/null || true)
        code="${code:-000}"
        if [ "$code" = "200" ]; then ok "ROCSPACE-INITIAL runtime reachable"; else warn "Runtime not reachable yet (HTTP $code)"; fi
      fi
      ;;
    enable:*|model:enable)
      if [ -z "$OCI_SSH_KEY" ] || [ ! -r "$OCI_SSH_KEY" ]; then
        warn "OCI_SSH_KEY is not set/readable; no remote action was performed."
        echo -e "  ${D}Set a valid private key path only in your shell:${N}"
        echo -e "  ${C}OCI_SSH_KEY=~/.ssh/oci_key hermes oci enable${N}"
        echo -e "  ${D}Or copy and run this on the OCI VM:${N}"
        echo -e "  ${C}curl -fsSL $OCI_MODEL_INSTALL_URL | bash${N}"
        return 2
      fi
      command -v ssh >/dev/null 2>&1 || { err "ssh is required"; return 1; }
      echo -e "${C}Starting private OCI model installer through Tailscale...${N}"
      # Download remotely rather than copying credentials or local configuration.
      ssh -i "$OCI_SSH_KEY" -o BatchMode=yes -o ConnectTimeout=20 "$VM_SSH_USER@$VM_TAILSCALE_IP" \
        "curl -fsSL '$OCI_MODEL_INSTALL_URL' | ROCSPACE_PERSONAL_MODEL='$OCI_MODEL_NAME' ROCSPACE_BASE_MODEL='$OCI_MODEL_BASE' bash"
      ;;
    endpoint:*|model:endpoint)
      echo "export ROCSPACE_PRIVATE_MODEL_BASE='$OCI_MODEL_TAILSCALE_URL'"
      echo "python3 tools/roc_autonomy.py run 'Reply only: ROCSPACE_INITIAL_OK' --model rocspace/initial"
      ;;
    install-cli:*|cli:*|install:*)
      header
      if [ "${1:-}" = "status" ]; then
        echo -e "${BOLD}🏛️  Oracle Cloud Infrastructure (OCI CLI) Status${N}\n"
        if command -v oci >/dev/null 2>&1 || python3 -m oci_cli --version >/dev/null 2>&1; then
          local ver; ver=$(oci --version 2>/dev/null || python3 -m oci_cli --version 2>/dev/null || echo "installed")
          ok "OCI CLI Version: $ver"
          if [ -f "$HOME/.oci/config" ]; then
            ok "Config File: $HOME/.oci/config (ap-singapore-1)"
          else
            warn "Config File missing: $HOME/.oci/config"
          fi
        else
          warn "OCI CLI is NOT installed in container. Run: hermes oci cli install"
        fi
      elif [ $# -gt 0 ] && [ "$1" != "install" ]; then
        oci "$@"
      else
        echo -e "${BOLD}🚀 Launching OCI CLI Installer for Termux & Container...${N}\n"
        bash "./oci/install_oci_cli.sh" "$@"
      fi
      ;;
    rdp:*|setup-rdp:*)
      local pass="${1:-}"
      header
      echo -e "${BOLD}🖥️ Installing Remote Desktop (xrdp + XFCE4) on OCI VM...${N}\n"
      echo -e "  Host Target: ${C}${VM_SSH_USER:-ubuntu}@${VM_IP:-161.118.253.28}${N}"
      echo -e "  RDP Port:    ${G}3389${N}\n"
      info "Running remote RDP setup via SSH..."
      local ssh_opts="-o StrictHostKeyChecking=no -o ConnectTimeout=10"
      [ -n "${OCI_SSH_KEY:-}" ] && [ -r "$OCI_SSH_KEY" ] && ssh_opts="$ssh_opts -i $OCI_SSH_KEY"
      ssh $ssh_opts "${VM_SSH_USER:-ubuntu}@${VM_IP:-161.118.253.28}" "bash -s -- $pass" < "./oci/setup-oci-rdp.sh"
      ok "RDP setup finished!"
      ;;
    tunnel:*|cf-tunnel:*)
      local port="${1:-11434}"
      header
      echo -e "${BOLD}🌐 Launching Cloudflare Tunnel for OCI Service (Port $port)...${N}\n"
      bash "./oci/setup-cf-tunnel.sh" "$port"
      ;;
    test:*|model:test)
      header
      echo -e "${BOLD}🧪 OCI / Termux smoke test${N}\n"
      _vm_probe "Canonical API health" "https://api.roadfx.biz.id/health" || true
      _vm_probe "Canonical model catalog" "https://api.roadfx.biz.id/v1/models" || true
      _vm_probe "Gateway provider status" "https://api.roadfx.biz.id/providers/status" || true
      if command -v tailscale >/dev/null 2>&1; then
        tailscale status 2>/dev/null | head -10 || warn "tailscale status unavailable"
      else
        warn "tailscale CLI not installed; private model test skipped"
      fi
      _vm_probe "Private ROCSPACE-INITIAL" "$OCI_MODEL_TAILSCALE_URL/api/tags" || true
      echo ""
      echo -e "  ${D}A private-model HTTP 000 is expected until OCI deployment completes.${N}"
      ;;
    *)
      err "Unknown OCI command: $sub $action"
      echo -e "  ${D}oci status | oci enable | oci endpoint | oci test | oci model [status|enable|endpoint|test]${N}"
      return 1 ;;
  esac
}

# ═════════════════════════════════════════════════════════════════════════════
#  AI CHAT (Interactive)
# ═════════════════════════════════════════════════════════════════════════════
cmd_chat() {
  local provider="${2:-${PROVIDER:-best}}"
  local model="${1:-${MODEL:-}}"
  local sel
  sel="$(_resolve_ai_runtime "$provider" "$model")"
  provider="${sel%%|*}"
  model="${sel#*|}"

  header
  echo -e "${BOLD}💬 Hermes Chat — Best AI${N} — ${C}${model}${N} (${provider})"
  echo -e "  ${D}Agent Mode | Agen AI Otonom untuk Tugas Dunia Nyata${N}"
  echo -e "  ${D}Jalankan agen AI otonom yang menjelajahi, meneliti, membuat kode, dan menyelesaikan tugas dunia nyata.${N}"
  echo -e "  ${D}Ketik / atau # untuk suggestion. /help untuk commands. /best untuk AI terbaik.${N}\n"
  if ! _provider_ready "$provider"; then
    warn "No active key detected for provider '$provider'. Run hermes setup or export PROVIDER/GEMINI_KEY/OR_KEY/GROQ_KEY."
  fi

  local messages="[]"
  local system_prompt="${SYSTEM:-Agent Mode | Agen AI Otonom untuk Tugas Dunia Nyata. You are ROCAgents & Hermes — an autonomous multi-agent AI assistant for sole creator Ivan Ssl (ivansslo). You have full direct access and authority to edit and modify all UI frontend components in src/ (App.tsx, ChatMessage.tsx, ChatInput.tsx, SyncDashboard.tsx, etc.) as well as all backend system files. NEVER claim that you cannot modify the UI. Locate the component, edit the file, and rebuild application assets immediately. Use the best available model/runtime, be accurate, take initiative on real-world tasks, and when helpful structure work as Planner → Researcher → Coder → Reviewer → Tester.}"

  while true; do
    hermes_read_input input "${G}You>${N} " "chat"
    [ -z "$input" ] && continue

    # Common slash commands. Keep these aligned with plugin suggestions.
    case "$input" in
      exit|quit|/exit|/quit)
        break
        ;;
      /help)
        echo -e "  ${W}Chat commands:${N}"
        echo -e "    ${C}/best${N}              Auto-pick strongest active AI from available keys"
        echo -e "    ${C}/model <name>${N}      Switch model"
        echo -e "    ${C}/provider <name>${N}   Switch provider: best, groq, openai, openrouter, gemini, gateway, cloudrun, cfai"
        echo -e "    ${C}/system <prompt>${N}   Replace system prompt"
        echo -e "    ${C}/clear${N}             Clear context"
        echo -e "    ${C}/save${N}              Save chat JSON"
        echo -e "    ${C}/plugins${N}           Show suggestion plugins"
        echo -e "    ${C}/agent <task>${N}      Run active code agent in current workspace"
        echo -e "    ${C}/exit${N}              Exit chat"
        echo -e "    ${D}Tags (#planner #coder #reviewer etc.) are sent as prompt context.${N}"
        continue
        ;;
      /best|/auto|/ai)
        sel="$(_best_ai_runtime)"
        provider="${sel%%|*}"
        model="${sel#*|}"
        echo -e "  ${G}✅${N} Best AI → ${C}$provider${N} / ${C}$model${N}"
        continue
        ;;
      /status)
        echo -e "  ${W}Provider:${N} $provider"
        echo -e "  ${W}Model:${N}    $model"
        echo -e "  ${W}Messages:${N} $(python3 -c 'import json,sys; print(len(json.loads(sys.argv[1])))' "$messages" 2>/dev/null || echo '?')"
        continue
        ;;
      /plugins)
        cmd_plugins list
        continue
        ;;
      /clear)
        messages="[]"
        echo -e "  ${C}Chat cleared${N}"
        continue
        ;;
      /save)
        mkdir -p "$HERMES_DIR"
        echo "$messages" > "$HERMES_DIR/chat_$(date +%s).json"
        ok "Chat saved"
        continue
        ;;
    esac

    if [[ "$input" == /model* ]]; then
      model="${input#/model }"
      [ -z "$model" ] || [ "$model" = "/model" ] && model="$(_default_model_for "$provider")"
      echo -e "  ${C}Model → $model${N}"
      continue
    fi
    if [[ "$input" == /provider* ]]; then
      provider="${input#/provider }"
      [ -z "$provider" ] || [ "$provider" = "/provider" ] && provider="best"
      sel="$(_resolve_ai_runtime "$provider" "")"
      provider="${sel%%|*}"
      model="${sel#*|}"
      echo -e "  ${C}Provider → $provider${N} / ${C}$model${N}"
      continue
    fi
    if [[ "$input" == /system* ]]; then
      system_prompt="${input#/system }"
      echo -e "  ${C}System prompt updated${N}"
      continue
    fi
    if [[ "$input" == /agent* ]]; then
      local task="${input#/agent }"
      if [ -n "$task" ] && [ "$task" != "/agent" ]; then
        HERMES_CODE_WORKSPACE="${HERMES_CODE_WORKSPACE:-$(pwd)}" cmd_code_agent "$task"
      else
        warn "Usage: /agent <task>"
      fi
      continue
    fi

    # Unknown slash commands should not silently call the LLM as commands.
    if [[ "$input" == /* ]]; then
      warn "Unknown chat command: $input"
      echo -e "  ${D}Type /help, or write normal text without leading slash.${N}"
      continue
    fi

    # Add user message (safe JSON via python3)
    messages=$(python3 -c "
import json,sys
msgs = json.loads(sys.argv[1])
msgs.append({'role':'user','content':sys.argv[2]})
print(json.dumps(msgs))
" "$messages" "$input" 2>/dev/null || echo "$messages")

    printf "${Y}AI>${N} "
    local response=""
    local oai_messages
    oai_messages=$(python3 -c "
import json,sys
system=sys.argv[1]
msgs=json.loads(sys.argv[2])
if system:
    msgs=[{'role':'system','content':system}] + msgs
print(json.dumps(msgs))
" "$system_prompt" "$messages" 2>/dev/null || echo "$messages")

    case "$provider" in
      groq)
        response=$(api_call POST "https://api.groq.com/openai/v1/chat/completions" \
          "{\"model\":\"$model\",\"messages\":$oai_messages,\"max_tokens\":4096,\"temperature\":0.7}" \
          "Bearer $GROQ_KEY")
        ;;
      openai|oai)
        response=$(api_call POST "https://api.openai.com/v1/chat/completions" \
          "{\"model\":\"$model\",\"messages\":$oai_messages,\"max_tokens\":16384,\"temperature\":0.7}" \
          "Bearer $OPENAI_KEY")
        ;;
      openrouter|or)
        response=$(api_call POST "https://openrouter.ai/api/v1/chat/completions" \
          "{\"model\":\"$model\",\"messages\":$oai_messages,\"max_tokens\":8192,\"temperature\":0.7}" \
          "Bearer $OR_KEY")
        ;;
      gemini)
        local gemini_msgs
        gemini_msgs=$(python3 -c "
import json,sys
msgs = json.loads(sys.argv[1])
sys_prompt = sys.argv[2]
parts = []
for m in msgs:
    r = 'model' if m['role']=='assistant' else 'user'
    parts.append({'role':r,'parts':[{'text':m['content']}]})
body = {'contents':parts,'generationConfig':{'temperature':0.7,'maxOutputTokens':8192}}
if sys_prompt:
    body['systemInstruction'] = {'parts':[{'text':sys_prompt}]}
print(json.dumps(body))
" "$messages" "$system_prompt" 2>/dev/null)
        response=$(api_call POST \
          "https://generativelanguage.googleapis.com/v1beta/models/$model:generateContent?key=$GEMINI_KEY" \
          "$gemini_msgs" "")
        local content
        content=$(printf '%s' "$response" | python3 -c "
import json,sys
raw = sys.stdin.read()
if not raw or not raw.strip():
    print('Error: empty response from Gemini API (check GEMINI_KEY / model name)')
    raise SystemExit(0)
try:
    d = json.loads(raw)
except Exception as e:
    print('Error: invalid JSON from Gemini: ' + str(e))
    print(raw[:400])
    raise SystemExit(0)
if isinstance(d, dict) and d.get('error'):
    err = d['error']
    if isinstance(err, dict):
        msg = err.get('message') or err.get('status') or str(err)
    else:
        msg = str(err)
    print('Error: ' + msg)
    raise SystemExit(0)
try:
    print(d['candidates'][0]['content']['parts'][0]['text'])
except Exception as e:
    print('Error: unexpected Gemini response: ' + str(e))
    print(raw[:400])
" 2>/dev/null)
        echo "$content"
        echo ""
        case "$content" in
          Error:*) continue ;;
        esac
        messages=$(python3 -c "
import json,sys
msgs = json.loads(sys.argv[1])
msgs.append({'role':'assistant','content':sys.argv[2]})
print(json.dumps(msgs))
" "$messages" "$content" 2>/dev/null || echo "$messages")
        continue
        ;;
      gateway)
        response=$(api_call POST "$GATEWAY/v1/chat/completions" \
          "{\"model\":\"$model\",\"messages\":$oai_messages,\"max_tokens\":8192}" \
          "Bearer $TOKEN")
        ;;
      ais|aisdev|newcr|ais-dev)
        response=$(api_call POST "$AIS_DEV/v1/chat/completions" \
          "{\"model\":\"$model\",\"messages\":$oai_messages,\"max_tokens\":8192}" \
          "Bearer $TOKEN")
        ;;
      cloudrun)
        response=$(api_call POST "$CLOUDRUN/v1/chat/completions" \
          "{\"model\":\"$model\",\"messages\":$oai_messages,\"max_tokens\":8192}" \
          "Bearer $TOKEN")
        ;;
      cf|cfai)
        response=$(api_call POST "$CF_AI/chat" \
          "{\"model\":\"$model\",\"messages\":$messages}" \
          "Bearer ${CF_AI_TOKEN:-$TOKEN}")
        ;;
      *)
        err "Provider not supported: $provider"
        continue
        ;;
    esac

    local content
    content=$(printf '%s' "$response" | python3 -c "
import json,sys
raw = sys.stdin.read()
if not raw or not raw.strip():
    print('Error: empty response from model API (check network / API key / model name)')
    raise SystemExit(0)
try:
    d = json.loads(raw)
except Exception as e:
    print('Error: invalid JSON from model API: ' + str(e))
    print(raw[:400])
    raise SystemExit(0)
# Surface provider errors clearly (wrong model name, bad key, rate limit, etc.)
if isinstance(d, dict) and d.get('error'):
    err = d['error']
    if isinstance(err, dict):
        msg = err.get('message') or err.get('code') or str(err)
    else:
        msg = str(err)
    print('Error: ' + msg)
    raise SystemExit(0)
try:
    print(d['choices'][0]['message']['content'])
except Exception:
    # Some gateways return {content: ...} or Gemini-style payloads
    try:
        print(d['candidates'][0]['content']['parts'][0]['text'])
    except Exception:
        print('Error: unexpected model response shape')
        print(raw[:400])
" 2>/dev/null || printf '%s' "$response" | head -c 500)

    echo "$content"
    echo ""

    # Do not pollute conversation history with API error strings.
    case "$content" in
      Error:*)
        continue
        ;;
    esac

    messages=$(python3 -c "
import json,sys
msgs = json.loads(sys.argv[1])
msgs.append({'role':'assistant','content':sys.argv[2]})
print(json.dumps(msgs))
" "$messages" "$content" 2>/dev/null || echo "$messages")
  done
}

# ═════════════════════════════════════════════════════════════════════════════
#  QUICK ASK (non-interactive)
# ═════════════════════════════════════════════════════════════════════════════
cmd_ask() {
  local question="$*"
  [ -z "$question" ] && { err "Usage: hermes ask <question>"; return 1; }

  local provider="${PROVIDER:-best}"
  local model="${MODEL:-}"
  local sel
  sel="$(_resolve_ai_runtime "$provider" "$model")"
  provider="${sel%%|*}"
  model="${sel#*|}"
  local safe_q
  safe_q=$(json_escape "$question")

  case "$provider" in
    openai|oai)
      local resp=$(api_call POST "https://api.openai.com/v1/chat/completions" \
        "{\"model\":\"$model\",\"messages\":[{\"role\":\"user\",\"content\":$safe_q}],\"max_tokens\":16384}" \
        "Bearer $OPENAI_KEY")
      echo "$resp" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['choices'][0]['message']['content'])" 2>/dev/null || echo "$resp" | head -c 500
      ;;
    gemini)
      local resp=$(curl -s --max-time 20 -X POST \
        "https://generativelanguage.googleapis.com/v1beta/models/$model:generateContent?key=$GEMINI_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"contents\":[{\"parts\":[{\"text\":$safe_q}]}],\"generationConfig\":{\"maxOutputTokens\":4096}}")
      echo "$resp" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['candidates'][0]['content']['parts'][0]['text'])" 2>/dev/null || echo "$resp" | head -c 500
      ;;
    openrouter|or)
      local resp=$(api_call POST "https://openrouter.ai/api/v1/chat/completions" \
        "{\"model\":\"$model\",\"messages\":[{\"role\":\"user\",\"content\":$safe_q}],\"max_tokens\":4096}" \
        "Bearer $OR_KEY")
      echo "$resp" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['choices'][0]['message']['content'])" 2>/dev/null || echo "$resp" | head -c 500
      ;;
    gateway)
      local resp=$(api_call POST "$GATEWAY/v1/chat/completions" \
        "{\"model\":\"$model\",\"messages\":[{\"role\":\"user\",\"content\":$safe_q}],\"max_tokens\":4096}" \
        "Bearer $TOKEN")
      echo "$resp" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['choices'][0]['message']['content'])" 2>/dev/null || echo "$resp" | head -c 500
      ;;
    ais|aisdev|newcr|ais-dev)
      local resp=$(api_call POST "$AIS_DEV/v1/chat/completions" \
        "{\"model\":\"$model\",\"messages\":[{\"role\":\"user\",\"content\":$safe_q}],\"max_tokens\":8192}" \
        "Bearer $TOKEN")
      echo "$resp" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['choices'][0]['message']['content'])" 2>/dev/null || echo "$resp" | head -c 500
      ;;
    cf|cfai)
      local cf_tok="${CF_AI_TOKEN:-$CF_TOKEN}"
      local cf_acc="${CF_ACCOUNT_ID:-37c44b4d3f192a627d20e46bdf910e79}"
      local resp=$(curl -s --max-time 30 -X POST \
        "https://api.cloudflare.com/client/v4/accounts/$cf_acc/ai/run/$model" \
        -H "Authorization: Bearer $cf_tok" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"role\":\"user\",\"content\":$safe_q}]}")
      echo "$resp" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('result',{}).get('choices',[{'message':{'content':''}}])[0].get('message',{}).get('content','') or d.get('result',{}).get('response',''))" 2>/dev/null || echo "$resp" | head -c 500
      ;;
    oci|ollama)
      local resp=$(curl -s --max-time 30 -X POST "$OCI_MODEL_ENDPOINT/api/generate" \
        -H "Content-Type: application/json" \
