cmd_antigravity() {
  local sub="${1:-status}"; shift 2>/dev/null || true
  case "$sub" in
    install|i)            _ag_install "$@" ;;
    update|upgrade)       _ag_install --force "$@" ;;
    status|s)             _ag_status ;;
    launch|run|open)      _ag_launch "$@" ;;
