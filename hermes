_vm_open() {  # buka URL di browser (Termux / desktop / fallback echo)
  local url="$1"
  if command -v termux-open-url &>/dev/null; then
    termux-open-url "$url" && ok "Opened: $url"
  elif command -v xdg-open &>/dev/null; then
    if xdg-open "$url" &>/dev/null; then ok "Opened: $url"; else echo -e "  ${C}$url${N}"; fi
  else
    echo -e "  ${C}$url${N}"
  fi
}

_vm_probe() {  # probe URL → print status baris; return 0 jika 2xx/3xx
  local name="$1" url="$2" code ms t0
  t0=$(date +%s%N 2>/dev/null || echo 0)
  code=$(curl -sS -m 8 -o /dev/null -w '%{http_code}' "$url" 2>/dev/null || true)
  code="${code:-000}"
  ms=$(( ($(date +%s%N 2>/dev/null || echo 0) - t0) / 1000000 ))
  case "$code" in
    2*|3*) printf "    ${G}●${N} %-22s ${G}%s${N} ${D}(%s ms)${N}\n" "$name" "$code" "$ms" ; return 0 ;;
    401|403) printf "    ${Y}●${N} %-22s ${Y}%s (auth)${N}\n" "$name" "$code" ; return 0 ;;
    405) printf "    ${Y}●${N} %-22s ${Y}405 (up — butuh method lain)${N}\n" "$name" ; return 0 ;;
    *) printf "    ${R}●${N} %-22s ${R}%s${N} ${D}$url${N}\n" "$name" "${code:-FAIL}" ; return 1 ;;
  esac
}

