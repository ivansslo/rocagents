cmd_github() {
  local action="${1:-status}"
  shift 2>/dev/null || true
  header
  echo -e "${BOLD}🐙 GitHub OAuth App — ROCAgents (Client ID: Ov23litvasZbgpCiNHIg)${N}\n"
  
  local clientId="${GITHUB_CLIENT_ID:-Ov23litvasZbgpCiNHIg}"
  local token="${GITHUB_OAUTH_TOKEN:-${GITHUB_PAT:-}}"

  case "$action" in
    status|user)
      if [ -n "$token" ]; then
        info "Checking GitHub user authentication..."
        local user
        user=$(curl -s -H "Authorization: Bearer $token" -H "User-Agent: ROCAgents-App" https://api.github.com/user 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin).get('login','?'))" 2>/dev/null)
        if [ "$user" != "?" ] && [ -n "$user" ]; then
          ok "Authenticated User: ${C}$user${N}"
          ok "GitHub App: ROCAgents ($clientId)"
        else
          warn "Token stored but failed GitHub user API check"
        fi
      else
        warn "GitHub OAuth/PAT token not configured. Run: hermes github device-flow or hermes setup"
      fi
      ;;
    device-flow|login|oauth)
      info "Requesting GitHub Device Flow activation code..."
      local dev_res
      dev_res=$(curl -s -X POST "https://github.com/login/device/code" \
        -H "Accept: application/json" \
        -d "client_id=$clientId&scope=repo,user,admin:repo_hook" 2>/dev/null)
      
      local user_code verification_uri device_code interval
      user_code=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('user_code',''))" "$dev_res" 2>/dev/null)
      verification_uri=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('verification_uri','https://github.com/login/device'))" "$dev_res" 2>/dev/null)
      device_code=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('device_code',''))" "$dev_res" 2>/dev/null)
      interval=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('interval', 5))" "$dev_res" 2>/dev/null)

      if [ -n "$user_code" ] && [ -n "$device_code" ]; then
        echo ""
        echo -e "  ${Y}======================================================${N}"
        echo -e "  ${G}🔑 PASSCODE  :${N} ${BOLD}${W}$user_code${N}"
        echo -e "  ${C}🔗 VERIFY URL:${N} ${BOLD}${C}$verification_uri${N}"
        echo -e "  ${Y}======================================================${N}"
        echo ""
        info "Opening verification URL in browser..."
        command -v termux-open-url >/dev/null 2>&1 && termux-open-url "$verification_uri" 2>/dev/null || xdg-open "$verification_uri" 2>/dev/null || true
        
        info "Waiting for device authorization on GitHub..."
        while true; do
          sleep "${interval:-5}"
          local poll_res
          poll_res=$(curl -s -X POST "https://github.com/login/oauth/access_token" \
            -H "Accept: application/json" \
            -d "client_id=$clientId&device_code=$device_code&grant_type=urn:ietf:params:oauth:grant-type:device_code" 2>/dev/null)
          
          local access_tok err_code
          access_tok=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('access_token',''))" "$poll_res" 2>/dev/null)
          err_code=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('error',''))" "$poll_res" 2>/dev/null)

          if [ -n "$access_tok" ]; then
            echo ""
            ok "GitHub Device Flow Authorized Successfully!"
            echo "GITHUB_OAUTH_TOKEN=$access_tok" >> "$HERMES_KEYS"
            chmod 600 "$HERMES_KEYS"
            export GITHUB_OAUTH_TOKEN="$access_tok"
            break
          elif [ "$err_code" = "authorization_pending" ]; then
            spinner "Authorization pending..."
          else
            err "Device authorization error: $err_code"
            break
          fi
        done
      else
        err "Failed to initiate Device Flow. Make sure 'Enable Device Flow' is checked in GitHub OAuth App settings!"
      fi
      ;;
    sync)
      curl -s -X POST http://localhost:3000/api/auth/github/sync | python3 -m json.tool
      ;;
    *)
      echo -e "Usage: ${BOLD}hermes github${N} [status|login|sync]"
      ;;
  esac
}

