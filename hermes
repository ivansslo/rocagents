hermes_read_input() {
  local __var="$1" prompt_text="$2" mode="${3:-chat}"
  local __line="" prompt_rendered="" have_tty=0 stdin_tty=0

  # Normalize any residual literal \033 / \e sequences into real ESC bytes.
  # Colors are already real ANSI ($'...') but keep this for callers that pass
  # quoted escape strings.
  printf -v prompt_rendered "%b" "$prompt_text"

  mkdir -p "$HERMES_DIR/tmp" "$HERMES_PLUGIN_DIR" 2>/dev/null || true

  # Probe the real console. Do not trust -r/-w alone: some environments expose
  # /dev/tty as a path that still fails to open (Errno 6 / ENXIO).
  if { : </dev/tty; } 2>/dev/null && { : >/dev/tty; } 2>/dev/null; then
    have_tty=1
  fi
  [ -t 0 ] && stdin_tty=1

  # Only use prompt_toolkit when a real console exists. The old here-doc
  # implementation fed the Python program through stdin, so prompt_toolkit saw
  # fd=0 as non-terminal and printed: "Warning: Input is not a terminal (fd=0)".
  # We force create_input/create_output against /dev/tty and silence the warning.
  if [ "${HERMES_NO_PROMPT_TOOLKIT:-}" != "1" ] && { [ "$stdin_tty" -eq 1 ] || [ "$have_tty" -eq 1 ]; }; then
    local py tmp script rc errf
    py="$(_hermes_python)"
    tmp="$HERMES_DIR/tmp/input_$$.txt"
    script="$HERMES_DIR/tmp/input_$$.py"
    errf="$HERMES_DIR/tmp/input_$$.err"

    if "$py" -c "import prompt_toolkit" >/dev/null 2>&1; then
      cat > "$script" <<'PYINPUT'
import os, re, sys, warnings
from pathlib import Path

# Termux / non-TTY hosts: suppress prompt_toolkit's noisy console warning.
warnings.filterwarnings("ignore", message=r".*not a terminal.*")

from prompt_toolkit import PromptSession
from prompt_toolkit.completion import Completer, Completion
from prompt_toolkit.formatted_text import ANSI
from prompt_toolkit.styles import Style

prompt_text = sys.argv[1]
mode = sys.argv[2] if len(sys.argv) > 2 else "chat"
out = os.environ.get("HERMES_INPUT_OUT")
plugin_dir = Path(os.environ.get("HERMES_PLUGIN_DIR", ""))

words = []
for line in os.environ.get("HERMES_BUILTIN_SUGGESTIONS", "").splitlines():
    line = line.strip()
    if re.match(r'^(/[A-Za-z0-9_-]+|#[A-Za-z0-9_-]+)$', line):
        words.append(line)

if plugin_dir.exists():
    for file in sorted(plugin_dir.glob("*.commands")):
        try:
            for line in file.read_text(errors="ignore").splitlines():
                line = line.strip()
                if re.match(r'^(/[A-Za-z0-9_-]+|#[A-Za-z0-9_-]+)$', line):
                    words.append(line)
        except Exception:
            pass

priority = []
if mode in ("coding", "code"):
    priority = ["/agent","/file","/preview","/run","/sh","/fix","/debug","/refactor","/test","/apply","/venv","/lang"]
elif mode in ("studio", "chat"):
    priority = ["/best","/ai","/model","/provider","/system","/plugins","/clear","/save","/agent","/crew","/research","/plan"]

seen = set()
ordered = []
for w in priority + words:
    if w not in seen:
        ordered.append(w)
        seen.add(w)

class HermesCompleter(Completer):
    def get_completions(self, document, complete_event):
        before = document.text_before_cursor
        m = re.search(r'([/#][\w.-]*)$', before)
        if not m:
            return
        frag = m.group(1)
        for w in ordered:
            if w.startswith(frag):
                meta = "command" if w.startswith("/") else "tag/plugin"
                yield Completion(w, start_position=-len(frag), display=w, display_meta=meta)

style = Style.from_dict({
    "completion-menu.completion": "bg:#1e1e1e #d7d7d7",
    "completion-menu.completion.current": "bg:#005f87 #ffffff bold",
    "completion-menu.meta.completion": "bg:#1e1e1e #87d7ff",
})

def _open_tty_io():
    """Bind prompt_toolkit to the real console, not a redirected stdin pipe.

    prompt_toolkit 3.x accepts always_prefer_tty=True which reopens /dev/tty
    when stdin/stdout are pipes — this is exactly the Termux failure mode that
    produced: Warning: Input is not a terminal (fd=0).
    """
    try:
        from prompt_toolkit.input import create_input
        from prompt_toolkit.output import create_output
        # Prefer the library's own tty re-open first.
        try:
            return (
                create_input(always_prefer_tty=True),
                create_output(always_prefer_tty=True),
            )
        except Exception:
            pass
        # Explicit /dev/tty fallback for older hosts.
        if os.path.exists("/dev/tty"):
            tty_in = open("/dev/tty", "rb", buffering=0)
            tty_out = open("/dev/tty", "w", encoding="utf-8", errors="replace")
            return create_input(stdin=tty_in), create_output(stdout=tty_out)
    except Exception:
        pass
    return None, None

text = "/exit"
try:
    inp, outp = _open_tty_io()
    if inp is not None and outp is not None:
        session = PromptSession(input=inp, output=outp)
    else:
        session = PromptSession()
    text = session.prompt(
        ANSI(prompt_text),
        completer=HermesCompleter(),
        complete_while_typing=True,
        reserve_space_for_menu=6,
        style=style,
    )
except (EOFError, KeyboardInterrupt):
    text = "/exit"
except Exception:
    # Any prompt_toolkit failure → let bash fallback handle input.
    sys.exit(2)

if out:
    Path(out).write_text(text, encoding="utf-8", errors="replace")
else:
    # Avoid printing prompt echo when output is redirected; bash reads HERMES_INPUT_OUT.
    print(text)
PYINPUT

      # Attach all three std streams to /dev/tty when possible so Termux never
      # reports "Input is not a terminal (fd=0)". Capture python stderr separately
      # so the warning cannot leak into the chat transcript if it still fires.
      if [ "$have_tty" -eq 1 ]; then
        HERMES_INPUT_OUT="$tmp" \
        HERMES_PLUGIN_DIR="$HERMES_PLUGIN_DIR" \
        HERMES_BUILTIN_SUGGESTIONS="$(_hermes_builtin_suggestions)" \
          "$py" "$script" "$prompt_rendered" "$mode" </dev/tty >/dev/tty 2>"$errf"
        rc=$?
      else
        HERMES_INPUT_OUT="$tmp" \
        HERMES_PLUGIN_DIR="$HERMES_PLUGIN_DIR" \
        HERMES_BUILTIN_SUGGESTIONS="$(_hermes_builtin_suggestions)" \
          "$py" "$script" "$prompt_rendered" "$mode" 2>"$errf"
        rc=$?
      fi
      rm -f "$script"
      # Drop the known non-fatal warning if it still appears on stderr.
      if [ -f "$errf" ]; then
        grep -v -E 'Input is not a terminal|Output is not a terminal' "$errf" >&2 2>/dev/null || true
        rm -f "$errf"
      fi
      if [ "$rc" -eq 0 ] && [ -f "$tmp" ]; then
        __line="$(cat "$tmp")"
        rm -f "$tmp"
        printf -v "$__var" '%s' "$__line"
        return 0
      fi
      rm -f "$tmp"
    fi
  fi

  # Plain fallback for pipes, scripts, unsupported terminals, or missing venv.
  # Always expand ANSI so Termux never shows "\033[0;32mYou>".
  if [ "$have_tty" -eq 1 ]; then
    printf "%b" "$prompt_rendered" >/dev/tty 2>/dev/null || printf "%b" "$prompt_rendered"
    if IFS= read -r __line </dev/tty; then
      printf -v "$__var" '%s' "$__line"
      return 0
    fi
  else
    printf "%b" "$prompt_rendered"
    if IFS= read -r __line; then
      printf -v "$__var" '%s' "$__line"
      return 0
    fi
  fi

  # EOF: tell callers to exit instead of looping forever.
  printf -v "$__var" '%s' "/exit"
  return 1
}

# ═════════════════════════════════════════════════════════════════════════════
#  INTERACTIVE CODING ASSISTANT
# ═════════════════════════════════════════════════════════════════════════════
cmd_coding() {
  header
  echo -e "${BOLD}⌘ Hermes Code Commands${N} — Interactive active-agent mode"
  echo -e "  ${D}Workspace:${N} ${HERMES_CODE_WORKSPACE:-$(pwd)}"
  echo -e "  ${D}Venv:${N}      $HERMES_VENV"
  echo ""
  echo -e "  ${D}Core:${N}"
  echo -e "    ${C}/agent <task>${N}     Active multi-step AI coding agent (read/write/run)"
  echo -e "    ${C}/run${N}              Run current code with python3_venv when lang=python"
  echo -e "    ${C}/debug${N}            AI debug current code"
  echo -e "    ${C}/refactor${N}         AI refactor current code"
  echo -e "    ${C}/fix${N}              AI fix current code"
  echo -e "    ${C}/test${N}             AI generate tests"
  echo -e "    ${C}/explain${N}          Explain current code"
  echo -e "  ${D}Files/shell:${N}"
  echo -e "    ${C}/file <path>${N}      Load file into context"
  echo -e "    ${C}/save [path]${N}      Save current context"
  echo -e "    ${C}/apply [path]${N}     Save last AI code block"
  echo -e "    ${C}/preview${N}          Syntax-highlight current code"
  echo -e "    ${C}/sh <cmd>${N}         Run shell command in workspace"
  echo -e "    ${C}/cd <dir>${N}         Change workspace"
  echo -e "    ${C}/ls [dir]${N}         List files"
  echo -e "  ${D}Runtime:${N}"
  echo -e "    ${C}/venv init|status|pip <pkg>${N}  Manage python3_venv"
  echo -e "    ${C}/lang <lang>${N}      python/js/bash/go/rust/etc"
  echo -e "    ${C}/clear${N}            Clear context"
  echo -e "    ${C}/exit${N}             Exit"
  echo ""

  local context=""
  local filename=""
  local lang="python"
  local last_code=""
  local workdir="${HERMES_CODE_WORKSPACE:-$(pwd)}"

  mkdir -p "$HERMES_DIR" "$workdir" 2>/dev/null || true

  while true; do
    local _prompt
    if [ -n "$filename" ]; then
      printf -v _prompt "${C}⌘${N} ${D}[%s|%s]${N} ${C}>${N} " "$lang" "$filename"
    else
      printf -v _prompt "${C}⌘${N} ${D}[%s]${N} ${C}>${N} " "$lang"
    fi
    hermes_read_input input "$_prompt" "coding"
    [ -z "$input" ] && continue
    [ "$input" = "/exit" ] || [ "$input" = "/quit" ] && break
    [[ "$input" == \#* ]] && continue

    case "$input" in
      /clear)
        context=""; filename=""; last_code=""
        ok "Context cleared"
        continue
        ;;
      /venv*)
        local args="${input#/venv}"
        # shellcheck disable=SC2086
        cmd_venv $args
        continue
        ;;
      /lang*)
        lang="${input#/lang }"
        [ "$lang" = "/lang" ] && lang="python"
        echo -e "  ${C}Language → $lang${N}"
        continue
        ;;
      /cd*)
        local target="${input#/cd }"
        [ "$target" = "/cd" ] && target="$HOME"
        if [ -d "$target" ]; then
          workdir="$(cd "$target" && pwd)"
          HERMES_CODE_WORKSPACE="$workdir"
          echo -e "  ${C}Workspace → $workdir${N}"
        elif [ -d "$workdir/$target" ]; then
          workdir="$(cd "$workdir/$target" && pwd)"
          HERMES_CODE_WORKSPACE="$workdir"
          echo -e "  ${C}Workspace → $workdir${N}"
        else
          err "Directory not found: $target"
        fi
        continue
        ;;
      /pwd)
        echo "  $workdir"
        continue
        ;;
      /ls*)
        local target="${input#/ls }"
        [ "$target" = "/ls" ] && target="."
        ( cd "$workdir" && ls -la "$target" ) 2>&1 | sed 's/^/  /'
        continue
        ;;
      /tree)
        ( cd "$workdir" && find . -maxdepth 3 -not -path './.git/*' -not -path './node_modules/*' | head -220 ) | sed 's/^/  /'
        continue
        ;;
      /sh*)
        local cmd="${input#/sh }"
        [ "$cmd" = "/sh" ] && { warn "Usage: /sh <command>"; continue; }
        echo -e "  ${BOLD}$ $cmd${N}"
        ( cd "$workdir" && timeout "${HERMES_SHELL_TIMEOUT:-120}" bash -lc "$cmd" ) 2>&1 | sed 's/^/    /'
        continue
        ;;
      /file*)
        local load_file="${input#/file }"
        [ "$load_file" = "/file" ] && { warn "Usage: /file <path>"; continue; }
        local full="$load_file"
        [ -f "$full" ] || full="$workdir/$load_file"
        if [ -f "$full" ]; then
          context=$(cat "$full")
          filename="$full"
          lang="$(_detect_lang_from_file "$full")"
          local lines=$(wc -l < "$full" | tr -d ' ')
          ok "Loaded: $full ($lines lines)"
          echo -e "  ${D}Detected language: $lang${N}"
        else
          err "File not found: $load_file"
        fi
        continue
        ;;
      /save*)
        local save_file="${input#/save }"
        [ "$save_file" = "/save" ] && save_file="${filename:-$workdir/output_$(date +%s).txt}"
        [ "$save_file" = "${save_file#/}" ] && save_file="$workdir/$save_file"
        if [ -z "$context" ]; then
          err "No code to save"
        else
          mkdir -p "$(dirname "$save_file")"
          printf "%s\n" "$context" > "$save_file"
          filename="$save_file"; lang="$(_detect_lang_from_file "$save_file")"
          ok "Saved to $save_file"
        fi
        continue
        ;;
      /apply*)
        local save_file="${input#/apply }"
        [ "$save_file" = "/apply" ] && save_file="${filename:-$workdir/ai_code_$(date +%s).txt}"
        [ "$save_file" = "${save_file#/}" ] && save_file="$workdir/$save_file"
        if [ -z "$last_code" ]; then
          err "No last AI code block to apply"
        else
          mkdir -p "$(dirname "$save_file")"
          printf "%s\n" "$last_code" > "$save_file"
          context="$last_code"; filename="$save_file"; lang="$(_detect_lang_from_file "$save_file")"
          ok "Applied last code to $save_file"
        fi
        continue
        ;;
      /preview|/cat)
        if [ -z "$context" ]; then err "No code loaded"; else printf "%s\n" "$context" | syntax_highlight "$lang"; fi
        continue
        ;;
      /run)
        if [ -z "$context" ]; then
          err "No code to run. Use /file or ask AI to generate code first."
          continue
        fi
        echo -e "  ${Y}▶ Running ($lang) in $workdir...${N}"
        echo ""
        _run_current_code "$lang" "$context" "$workdir" | sed 's/^/    /'
        echo ""
        continue
        ;;
      /agent*)
        local task="${input#/agent }"
        [ "$task" = "/agent" ] && { warn "Usage: /agent <complex coding task>"; continue; }
        HERMES_CODE_WORKSPACE="$workdir" cmd_code_agent "$task"
        continue
        ;;
      /debug)
        [ -z "$context" ] && { err "No code to debug"; continue; }
        echo -e "  ${Y}🔍 Debugging...${N}\n"
        cmd_ask_internal "Debug this $lang code. Find bugs, logic errors, performance issues, and security problems. Include concrete fixes.\n\n\`\`\`$lang\n$context\n\`\`\`" "You are a senior $lang developer and code reviewer. Be precise and actionable." | render_markdown
        echo ""
        continue
        ;;
      /refactor)
        [ -z "$context" ] && { err "No code to refactor"; continue; }
        echo -e "  ${Y}♻️  Refactoring...${N}\n"
        local response
        response=$(cmd_ask_internal "Refactor this $lang code for readability, performance, and maintainability. Return the refactored code in a fenced code block.\n\n\`\`\`$lang\n$context\n\`\`\`" "You are a senior $lang developer. Output clean refactored code in a code block, with concise notes.")
        printf "%s\n" "$response" | render_markdown
        last_code=$(printf "%s" "$response" | _extract_code_block)
        if [ -n "$last_code" ] && [ -t 0 ]; then
          printf "  ${D}Replace context with refactored code? [y/N]:${N} "
          read -r confirm
          [[ "$confirm" =~ ^[Yy]$ ]] && { context="$last_code"; ok "Context updated"; }
        fi
        echo ""
        continue
        ;;
      /fix)
        [ -z "$context" ] && { err "No code to fix"; continue; }
        echo -e "  ${Y}🔧 Fixing...${N}\n"
        local response
        response=$(cmd_ask_internal "Fix all errors and issues in this $lang code. Return corrected code in a fenced code block.\n\n\`\`\`$lang\n$context\n\`\`\`" "You are a senior $lang developer. Fix bugs and output corrected code in a code block.")
        printf "%s\n" "$response" | render_markdown
        last_code=$(printf "%s" "$response" | _extract_code_block)
        if [ -n "$last_code" ] && [ -t 0 ]; then
          printf "  ${D}Replace context with fixed code? [y/N]:${N} "
          read -r confirm
          [[ "$confirm" =~ ^[Yy]$ ]] && { context="$last_code"; ok "Context updated"; }
        fi
        echo ""
        continue
        ;;
      /explain)
        [ -z "$context" ] && { err "No code to explain"; continue; }
        cmd_ask_internal "Explain this $lang code step by step in simple terms:\n\n\`\`\`$lang\n$context\n\`\`\`" "You are a patient coding teacher. Explain clearly for beginners." | render_markdown
        echo ""
        continue
        ;;
      /test)
        [ -z "$context" ] && { err "No code to test"; continue; }
        cmd_ask_internal "Generate comprehensive tests for this $lang code. Include edge cases and how to run them.\n\n\`\`\`$lang\n$context\n\`\`\`" "You are a QA engineer. Write thorough tests with good coverage." | render_markdown
        echo ""
        continue
        ;;
    esac

    local full_prompt="$input"
    if [ -n "$context" ]; then
      full_prompt="Current workspace: $workdir\nCurrent file: ${filename:-none}\nCurrent $lang code:\n\`\`\`$lang\n$context\n\`\`\`\n\nUser request: $input"
    fi

    local response
    response=$(cmd_ask_internal "$full_prompt" "You are Hermes Code, an expert active AI programming assistant. Provide clean, efficient code with concise explanation. Use fenced markdown code blocks for code. Prefer commands that work in Termux/Linux. Mention if python3_venv is needed.")
    echo ""
    printf "%s\n" "$response" | render_markdown
    echo ""

    last_code=$(printf "%s" "$response" | _extract_code_block)
    if [ -n "$last_code" ]; then
      echo -e "  ${D}Detected code block. Commands: /apply [file], /preview, /run${N}"
      if [ -t 0 ]; then
        printf "  ${D}Use this code as context? [y/N]:${N} "
        read -r use_code
        if [[ "$use_code" =~ ^[Yy]$ ]]; then
          context="$last_code"
          ok "Context updated"
        fi
      fi
    fi
    echo ""
  done
}

# ─── Code Generation (non-interactive) ──────────────────────────────────────
cmd_code() {
  local prompt="$*"
  [ -z "$prompt" ] && { err "Usage: hermes code <description>"; return 1; }

  local provider="${PROVIDER:-best}"
  local model="${MODEL:-}"
  local sel
  sel="$(_resolve_ai_runtime "$provider" "$model")"
  provider="${sel%%|*}"
  model="${sel#*|}"

  header
  echo -e "${BOLD}⌘ Code Generation AI${N} — ${C}${model}${N} (${provider})\n"
  info "Generating code for: $prompt"
  echo ""

  local system="You are a senior software engineer. Generate clean, modular, production-ready code in a fenced code block with concise comments."
  local resp=$(cmd_ask_internal "Generate code for: $prompt" "$system")

  printf "%s\n" "$resp" | render_markdown
}

# ═════════════════════════════════════════════════════════════════════════════
#  WEB CRAWL
# ═════════════════════════════════════════════════════════════════════════════
cmd_crawl() {
  local url="$1"
  [ -z "$url" ] && { err "Usage: hermes crawl <url>"; return 1; }

  header
  echo -e "${BOLD}🕷️ Crawl4AI${N} — $url\n"
  info "Crawling..."

  local resp=$(api_call POST "$GATEWAY/crawl4ai" \
    "{\"url\":\"$url\",\"max_length\":50000}" \
    "Bearer $TOKEN")

  echo "$resp" | python3 -m json.tool 2>/dev/null || echo "$resp" | head -c 5000
  echo ""

  # Save option (skip if non-interactive)
  if [ -t 0 ]; then
    printf "  ${D}Save to file? [filename or Enter to skip]:${N} "
    read -r fname
    if [ -n "$fname" ]; then
      echo "$resp" > "$fname"
      ok "Saved to $fname"
    fi
  fi
}

# ═════════════════════════════════════════════════════════════════════════════
#  CREWAI MULTI-AGENT
# ═════════════════════════════════════════════════════════════════════════════
cmd_crew() {
  local topic="${*:-AI agents in 2026}"
  header
  echo -e "${BOLD}🤖 CrewAI Multi-Agent${N}\n"
  info "Topic: $topic"
  info "Agents: Researcher → Analyst → Writer"
  info "Sending to Hermes Gateway..."
  echo ""

  local safe_topic
  safe_topic=$(json_escape "You are a research crew. Research, analyze, and write a comprehensive report about: $topic. Structure: 1) Key Findings, 2) Analysis, 3) Recommendations.")

  local resp=$(api_call POST "$GATEWAY/solace/task" \
    "{\"type\":\"chat\",\"prompt\":$safe_topic,\"model\":\"llama-3.3-70b-versatile\",\"max_tokens\":4096}" \
    "Bearer $TOKEN")

  echo "$resp" | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    c=d.get('choices',[{}])[0].get('message',{}).get('content','')
    if c: print(c)
    else: print(json.dumps(d,indent=2)[:3000])
except: print(sys.stdin.read()[:3000])
" 2>/dev/null || echo "$resp" | head -c 3000
}

# ═════════════════════════════════════════════════════════════════════════════
#  VOYAGE AI EMBEDDINGS
# ═════════════════════════════════════════════════════════════════════════════
cmd_embed() {
  local text="$*"
  [ -z "$text" ] && { err "Usage: hermes embed <text>"; return 1; }
  [ -z "$VOYAGE_KEY" ] && { err "VOYAGE_KEY not set. Run: hermes setup"; return 1; }

  header
  echo -e "${BOLD}🧠 Voyage AI Embedding${N}\n"
  info "Generating embedding..."

  local resp=$(curl -s --max-time 15 -X POST "https://api.voyageai.com/v1/embeddings" \
    -H "Authorization: Bearer $VOYAGE_KEY" \
    -H "Content-Type: application/json" \
    -d "{\"model\":\"voyage-3-lite\",\"input\":[\"$text\"]}")

  echo "$resp" | python3 -c "
import json,sys
d=json.load(sys.stdin)
if 'data' in d:
    emb=d['data'][0]['embedding']
    print(f'  Dimensions: {len(emb)}')
    print(f'  Model: voyage-3-lite')
    print(f'  First 5 values: {emb[:5]}')
    print(f'  Text: {sys.argv[1][:80]}...')
else:
    print('  Error: ' + json.dumps(d)[:200])
" "$text" 2>/dev/null
}

# ═════════════════════════════════════════════════════════════════════════════
#  FIREBASE
# ═════════════════════════════════════════════════════════════════════════════
# ─── Firebase Admin SDK (self-serve service account) ─────────────────────
# Key lookup order:
#   $FIREBASE_SERVICE_ACCOUNT → ~/.hermes/serviceAccountKey.json
#   → <hermes_dir>/assets/serviceAccountKey.json → ADC ($GOOGLE_APPLICATION_CREDENTIALS)
cmd_firebase_admin() {
  local action="${1:-status}"
  [ $# -gt 0 ] && shift

  local sa="${FIREBASE_SERVICE_ACCOUNT:-}"
  [ -z "$sa" ] && [ -f "$HERMES_DIR/serviceAccountKey.json" ] && sa="$HERMES_DIR/serviceAccountKey.json"
  if [ -z "$sa" ]; then
    local cli_dir
    cli_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)"
    [ -f "$cli_dir/assets/serviceAccountKey.json" ] && sa="$cli_dir/assets/serviceAccountKey.json"
  fi

  FIREBASE_SA_PATH="$sa" "$(_hermes_python)" - "$action" "$@" <<'FIREBASE_ADMIN_PY'
import json, os, sys, datetime

sa  = os.environ.get("FIREBASE_SA_PATH", "").strip()
adc = os.environ.get("GOOGLE_APPLICATION_CREDENTIALS", "").strip()
args   = sys.argv[1:]
action = args[0] if args else "status"

try:
    import firebase_admin
    from firebase_admin import credentials, firestore
except ImportError:
    print("ERROR: modul 'firebase_admin' belum terpasang.")
    print("Fix:")
    print("  hermes venv init                  (siapkan venv Hermes)")
    print("  hermes venv pip firebase-admin    (install SDK ke venv)")
    print("  # Termux bila build grpcio gagal: pkg install python-grpcio -y")
    sys.exit(2)

if not firebase_admin._apps:
    if sa and os.path.isfile(sa):
        cred = credentials.Certificate(sa)
    elif adc:
        cred = credentials.ApplicationDefault()
    else:
        home = os.environ.get("HOME", "~")
        print("ERROR: serviceAccountKey.json tidak ditemukan.")
        print("Self-serve:")
        print("  1. Firebase Console -> Project Settings -> Service accounts")
        print("     -> klik 'Generate new private key'")
        print("  2. Simpan key ke salah satu lokasi:")
        print(f"       {home}/.hermes/serviceAccountKey.json")
        print("       assets/serviceAccountKey.json  (di repo, sudah di-gitignore)")
        print("     atau: export FIREBASE_SERVICE_ACCOUNT=/path/key.json")
        print("  3. Ulangi: hermes firebase admin status")
        sys.exit(3)
    firebase_admin.initialize_app(cred)

db  = firestore.client()
app = firebase_admin.get_app()

if action == "status":
    print("project   :", app.project_id)
    print("credential:", ("service-account " + sa) if sa else "Application Default (ADC)")
    cols = list(db.collections())
    print("collections:", len(cols))
    for c in cols:
        n = sum(1 for _ in c.limit(50).stream())
        print(f"  - {c.id} ({n} docs, maks 50 ditampilkan)")

elif action == "list":
    col   = args[1] if len(args) > 1 else "chats"
    limit = int(args[2]) if len(args) > 2 else 10
    n = 0
    for d in db.collection(col).limit(limit).stream():
        n += 1
        print(f"{d.id}: {json.dumps(d.to_dict(), ensure_ascii=False)[:200]}")
    if n == 0:
        print(f"(kosong atau tidak ada akses: {col})")

elif action == "save":
    msg = " ".join(args[1:]).strip()
    if not msg:
        print("Usage: hermes firebase admin save <message>")
        sys.exit(1)
    col = os.environ.get("FIREBASE_COLLECTION", "chats")
    _, ref = db.collection(col).add({
        "sender": "hermes-cli",
        "text": msg,
        "timestamp": datetime.datetime.now(datetime.timezone.utc),
    })
    print("saved:", ref.id, f"(collection: {col})")

else:
    print("Admin commands: status | list [collection] [limit] | save <message>")
FIREBASE_ADMIN_PY
}

