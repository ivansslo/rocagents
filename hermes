_ag_vnc_stop() {
  local pidfile="$HOME/.hermes/antigravity-vnc.pid"
  if [ -f "$pidfile" ]; then
    kill $(cat "$pidfile") 2>/dev/null || true
    rm -f "$pidfile"
    _ag_ok "Antigravity VNC dihentikan"
  else
    _ag_note "tidak ada sesi VNC tercatat"
  fi
}

_ag_vnc() {  # [port] | stop — headless VNC: Xvfb+x11vnc atau Xvnc (TigerVNC)
  [ "${1:-}" = "stop" ] && { _ag_vnc_stop; return; }
  local port="${1:-$AG_VNC_PORT}"
  [ -x "$AG_BIN" ] || { err "belum terinstall — jalankan: hermes antigravity install"; return 1; }
  case "$(uname -m)" in
    aarch64|arm64) : ;;
    *) err "paket ARM aarch64 tidak bisa jalan di $(uname -m)"; return 1 ;;
  esac
  _ag_glibc_ready || { err "interpreter glibc aarch64 tidak ada — pakai proot-distro / Oracle VM"; return 1; }
  local disp=":99" mode="" xp=""
  mkdir -p "$HOME/.hermes"
  if command -v Xvfb >/dev/null 2>&1 && command -v x11vnc >/dev/null 2>&1; then
    mode="Xvfb + x11vnc"
    Xvfb "$disp" -screen 0 1280x800x24 >/dev/null 2>&1 & xp=$!
    sleep 1
    if ! x11vnc -display "$disp" -rfbport "$port" -localhost -nopw -forever -bg -quiet >/dev/null 2>&1; then
      kill "$xp" 2>/dev/null; err "x11vnc gagal start di port $port"; return 1
    fi
  elif command -v Xvnc >/dev/null 2>&1; then
    mode="Xvnc (TigerVNC)"
    Xvnc "$disp" -geometry 1280x800 -rfbport "$port" -localhost -SecurityTypes None >/dev/null 2>&1 & xp=$!
    sleep 1
  else
    err "butuh Xvfb+x11vnc atau Xvnc:"
    echo -e "    ${D}Oracle VM : ${C}sudo apt install -y xvfb x11vnc"
    echo -e "    ${D}Termux    : ${C}pkg install tigervnc${N}"
    return 1
  fi
  # shellcheck disable=SC2086
  DISPLAY="$disp" nohup "$AG_BIN" --no-sandbox ${ANTIGRAVITY_FLAGS:-} >/dev/null 2>&1 & local ap=$!
  echo "$xp $ap" > "$HOME/.hermes/antigravity-vnc.pid"
  _ag_ok "Antigravity berjalan (mode: $mode, DISPLAY $disp)"
  echo -e "  ${W}VNC listen:${N} localhost:$port  ${D}(tidak diekspos publik)${N}"
  echo -e "  ${W}Akses     :${N} sambungkan noVNC/websockify → localhost:$port"
  echo -e "              ${D}di VM: panel noVNC $VM_NOVNC_URL atau websockify :6080${N}"
  _ag_note "Stop: hermes antigravity vnc stop   (PID: $(cat "$HOME/.hermes/antigravity-vnc.pid"))"
}

_ag_uninstall() {
  _ag_vnc_stop >/dev/null 2>&1 || true
  local gone=""
  [ -d "$AG_DIR" ] && { rm -rf "$AG_DIR"; gone="$gone dir"; }
  if [ -e "$AG_LINK" ] || [ -L "$AG_LINK" ]; then rm -f "$AG_LINK"; gone="$gone symlink"; fi
  [ -n "$gone" ] && _ag_ok "dihapus:${gone}" || _ag_note "tidak ada yang terinstall"
}

