_hermes_python() {
  if [ -x "$HERMES_VENV/bin/python" ]; then
    echo "$HERMES_VENV/bin/python"
  else
    echo "python3"
  fi
}

_has_py_mod() {
  local mod="$1" py
  py="$(_hermes_python)"
  "$py" -c "import $mod" >/dev/null 2>&1
}

render_markdown() {
  local py
  py="$(_hermes_python)"
  if "$py" -c "import rich" >/dev/null 2>&1; then
    "$py" -c "
import sys
from rich.console import Console
from rich.markdown import Markdown
Console().print(Markdown(sys.stdin.read()))
" 2>/dev/null || cat
  else
    cat
  fi
}

syntax_highlight() {
  local lang="${1:-text}" py
  py="$(_hermes_python)"
  if "$py" -c "import pygments" >/dev/null 2>&1; then
    "$py" -c '
import sys
from pygments import highlight
from pygments.lexers import get_lexer_by_name, TextLexer
from pygments.formatters import Terminal256Formatter
lang = sys.argv[1] if len(sys.argv) > 1 else "text"
code = sys.stdin.read()
try:
    lexer = get_lexer_by_name(lang)
except Exception:
    lexer = TextLexer()
print(highlight(code, lexer, Terminal256Formatter(style="monokai")), end="")
' "$lang" 2>/dev/null || cat
  else
    cat
  fi
}

_extract_code_block() {
  python3 -c "
import re,sys
text=sys.stdin.read()
blocks=re.findall(r'```(?:[a-zA-Z0-9_+.#-]+)?\n(.*?)```', text, re.S)
if blocks:
    print(blocks[0].strip())
" 2>/dev/null
}

_extract_json_object() {
  python3 -c '
import json,re,sys
text=sys.stdin.read().strip()
m=re.search(r"```(?:json)?\s*(\{.*?\})\s*```", text, re.S)
if m:
    text=m.group(1)
else:
    start=text.find("{"); end=text.rfind("}")
    text=text[start:end+1] if start!=-1 and end!=-1 and end>start else text
try:
    obj=json.loads(text)
    print(json.dumps(obj))
except Exception:
    sys.exit(1)
' 2>/dev/null
}

_detect_lang_from_file() {
  case "$1" in
    *.py) echo "python" ;;
    *.js|*.mjs|*.cjs) echo "javascript" ;;
    *.ts|*.tsx) echo "typescript" ;;
    *.jsx) echo "jsx" ;;
    *.sh|*.bash) echo "bash" ;;
    *.go) echo "go" ;;
    *.rs) echo "rust" ;;
    *.java) echo "java" ;;
    *.json) echo "json" ;;
    *.md) echo "markdown" ;;
    *.html) echo "html" ;;
    *.css) echo "css" ;;
    *) echo "text" ;;
  esac
}

cmd_venv() {
  local action="${1:-status}"
  shift 2>/dev/null || true

  case "$action" in
    init|create|setup|install)
      header
      echo -e "${BOLD}🐍 Hermes python3_venv${N}\n"
      command -v python3 >/dev/null 2>&1 || { err "python3 not found. Termux: pkg install python"; return 1; }
      mkdir -p "$HERMES_DIR"
      if [ ! -x "$HERMES_VENV/bin/python" ]; then
        info "Creating venv: $HERMES_VENV"
        python3 -m venv "$HERMES_VENV" 2>/dev/null || {
          err "Could not create venv. Debian/Ubuntu: apt install python3-venv. Termux: pkg install python"
          return 1
        }
      else
        ok "Venv already exists: $HERMES_VENV"
      fi
      "$HERMES_VENV/bin/python" -m pip install -U pip setuptools wheel >/dev/null 2>&1 || warn "pip upgrade failed"
      info "Installing responsive CLI renderer: rich, pygments, prompt_toolkit, requests"
      "$HERMES_VENV/bin/python" -m pip install -U rich pygments prompt_toolkit requests >/dev/null 2>&1 \
        && ok "Code command runtime ready" \
        || warn "Some Python packages failed to install"
      echo ""
      echo -e "  ${D}Use: hermes coding  → /venv status, /run, /preview, /agent${N}"
      ;;
    status)
      header
      echo -e "${BOLD}🐍 python3_venv Status${N}\n"
      if [ -x "$HERMES_VENV/bin/python" ]; then
        ok "Venv: $HERMES_VENV"
        echo -e "  ${W}Python:${N} $("$HERMES_VENV/bin/python" --version 2>&1)"
        for mod in rich pygments prompt_toolkit requests; do
          "$HERMES_VENV/bin/python" -c "import $mod" >/dev/null 2>&1 \
            && printf "  ${G}✅${N} %s\n" "$mod" \
            || printf "  ${R}❌${N} %s\n" "$mod"
        done
      else
        warn "Venv not created: $HERMES_VENV"
        echo -e "  ${C}Run:${N} hermes venv init"
      fi
      ;;
    pip|install-pkg|pkg)
      [ -x "$HERMES_VENV/bin/python" ] || cmd_venv init
      [ $# -gt 0 ] || { err "Usage: hermes venv pip <packages...>"; return 1; }
      "$HERMES_VENV/bin/python" -m pip install -U "$@"
      ;;
    run)
      [ -x "$HERMES_VENV/bin/python" ] || { err "Venv not found. Run: hermes venv init"; return 1; }
      "$HERMES_VENV/bin/python" "$@"
      ;;
    shell|activate)
      echo "source \"$HERMES_VENV/bin/activate\""
      ;;
    *)
      echo -e "  ${W}Usage:${N} hermes venv [init|status|pip <pkg>|run <script>|activate]"
      ;;
  esac
}

_run_current_code() {
  local lang="$1" code="$2" workdir="${3:-$(pwd)}"
  local py tmp rc
  mkdir -p "$HERMES_DIR/tmp"
  case "$lang" in
    python|py)
      py="$(_hermes_python)"
      tmp="$HERMES_DIR/tmp/run_$$.py"
      printf "%s\n" "$code" > "$tmp"
      ( cd "$workdir" && timeout "${HERMES_RUN_TIMEOUT:-60}" "$py" "$tmp" ) 2>&1
      rc=$?; rm -f "$tmp"; return $rc
      ;;
    bash|sh)
      tmp="$HERMES_DIR/tmp/run_$$.sh"
      printf "%s\n" "$code" > "$tmp"
      ( cd "$workdir" && timeout "${HERMES_RUN_TIMEOUT:-60}" bash "$tmp" ) 2>&1
      rc=$?; rm -f "$tmp"; return $rc
      ;;
    node|js|javascript)
      tmp="$HERMES_DIR/tmp/run_$$.js"
      printf "%s\n" "$code" > "$tmp"
      ( cd "$workdir" && timeout "${HERMES_RUN_TIMEOUT:-60}" node "$tmp" ) 2>&1
      rc=$?; rm -f "$tmp"; return $rc
      ;;
    ts|typescript)
      tmp="$HERMES_DIR/tmp/run_$$.ts"
      printf "%s\n" "$code" > "$tmp"
      ( cd "$workdir" && timeout "${HERMES_RUN_TIMEOUT:-60}" npx ts-node "$tmp" ) 2>&1
      rc=$?; rm -f "$tmp"; return $rc
      ;;
    go)
      tmp="$HERMES_DIR/tmp/run_$$.go"
      printf "%s\n" "$code" > "$tmp"
      ( cd "$workdir" && timeout "${HERMES_RUN_TIMEOUT:-60}" go run "$tmp" ) 2>&1
      rc=$?; rm -f "$tmp"; return $rc
      ;;
    rust|rs)
      tmp="$HERMES_DIR/tmp/run_$$.rs"
      printf "%s\n" "$code" > "$tmp"
      ( cd "$workdir" && timeout "${HERMES_RUN_TIMEOUT:-60}" rustc "$tmp" -o "$HERMES_DIR/tmp/run_$$" && "$HERMES_DIR/tmp/run_$$" ) 2>&1
      rc=$?; rm -f "$tmp" "$HERMES_DIR/tmp/run_$$"; return $rc
      ;;
    *)
      echo "Cannot run language '$lang' directly. Use /save then run manually."
      return 2
      ;;
  esac
}

cmd_code_agent() {
  local task="$*"
  [ -z "$task" ] && { err "Usage: hermes agent <complex coding task>"; return 1; }
  local workdir="${HERMES_CODE_WORKSPACE:-$(pwd)}"
  local max_steps="${HERMES_AGENT_STEPS:-6}"
  local last=""

  header
  echo -e "${BOLD}🤖 Active Code Agent${N} — ${D}$workdir${N}"
  echo -e "  ${D}Steps: $max_steps | venv: $HERMES_VENV${N}\n"

  for step in $(seq 1 "$max_steps"); do
    echo -e "${Y}── Step $step/$max_steps ──${N}"
    local files
    files=$(cd "$workdir" 2>/dev/null && find . -maxdepth 3 -type f \
      -not -path './.git/*' -not -path './node_modules/*' -not -path './.venv/*' -not -path './venv/*' \
      | sed 's#^./##' | head -160)

    local prompt="You are Hermes active code agent running inside a local CLI. Complete this task safely and iteratively.\n\nTask: $task\n\nWorkspace: $workdir\nFiles (first 160):\n$files\n\nLast command/result:\n$last\n\nReturn EXACTLY one JSON object, no markdown, with one action:\n{\"thought\":\"short reason\",\"action\":\"shell|read|write|done\",\"command\":\"command for shell\",\"path\":\"relative path for read/write\",\"content\":\"full file content for write\",\"message\":\"final/user message\"}\nRules: use shell for tests/inspection, read before editing unknown files, write full file content only, use shell to run tests, use python3_venv if Python packages are needed ($HERMES_VENV), finish with done when complete."

    local response json action thought cmd path content message
    response=$(cmd_ask_internal "$prompt" "You are a precise autonomous software engineering agent. Output only valid compact JSON.")
    json=$(printf "%s" "$response" | _extract_json_object)
    if [ -z "$json" ]; then
      warn "AI did not return valid JSON; raw response:"
      printf "%s\n" "$response" | render_markdown
      return 1
    fi
    action=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("action",""))' "$json" 2>/dev/null)
    thought=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("thought",""))' "$json" 2>/dev/null)
    echo -e "  ${C}Thought:${N} $thought"

    case "$action" in
      shell)
        cmd=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("command",""))' "$json" 2>/dev/null)
        [ -z "$cmd" ] && { warn "Empty shell command"; last="empty shell command"; continue; }
        echo -e "  ${BOLD}$ ${cmd}${N}"
        local out rc
        out=$(cd "$workdir" && timeout "${HERMES_AGENT_CMD_TIMEOUT:-90}" bash -lc "$cmd" 2>&1); rc=$?
        printf "%s\n" "$out" | sed 's/^/    /' | head -220
        last="command: $cmd\nexit: $rc\noutput:\n$(printf "%s" "$out" | tail -80)"
        ;;
      read)
        path=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("path",""))' "$json" 2>/dev/null)
        if [ -f "$workdir/$path" ]; then
          echo -e "  ${C}Reading:${N} $path"
          local data
          data=$(sed -n '1,240p' "$workdir/$path")
          printf "%s\n" "$data" | syntax_highlight "$(_detect_lang_from_file "$path")"
          last="file: $path\ncontent:\n$data"
        else
          warn "File not found: $path"; last="file not found: $path"
        fi
        ;;
      write)
        path=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("path",""))' "$json" 2>/dev/null)
        content=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("content",""), end="")' "$json" 2>/dev/null)
        [ -z "$path" ] && { warn "Empty write path"; last="empty write path"; continue; }
        mkdir -p "$(dirname "$workdir/$path")"
        printf "%s" "$content" > "$workdir/$path"
        ok "Wrote $path ($(printf "%s" "$content" | wc -l | tr -d ' ') lines)"
        last="wrote file: $path"
        ;;
      done)
        message=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("message","Done."))' "$json" 2>/dev/null)
        ok "$message"
        return 0
        ;;
      *)
        warn "Unknown action: $action"; last="unknown action: $action"
        ;;
    esac
    echo ""
  done
  warn "Reached max steps ($max_steps). Continue with: HERMES_AGENT_STEPS=10 hermes agent <task>"
}

