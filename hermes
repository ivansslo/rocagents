# ─── Antigravity IDE — installer & launcher (linux/ARM64) ───────────────────
_ag_ok()   { echo -e "  ${G}✅${N} $*"; }
_ag_note() { echo -e "  ${D}$*${N}"; }

_ag_is_default_build() { [ "$AG_URL" = "$AG_URL_DEFAULT" ]; }
_ag_glibc_ready()      { [ -e /lib/ld-linux-aarch64.so.1 ]; }

_ag_dl() {  # <url> <dest> — https:// dengan resume (-C -)
  case "$1" in
    http://*|https://*) curl -fL --retry 3 -C - -o "$2" "$1" ;;
    *) err "URL tidak didukung: $1 (http(s):// atau file:// / path lokal)"; return 1 ;;
  esac
}

_ag_verify() {  # <file> — size + MD5 hanya utk build pinned default
  local f="$1"
  _ag_is_default_build || { warn "custom URL/build — verifikasi size/MD5 di-skip"; return 0; }
  local sz; sz=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null)
  [ "$sz" = "$AG_SIZE_EXPECTED" ] || { err "size mismatch: $sz ≠ $AG_SIZE_EXPECTED (download korup / build berubah)"; return 1; }
  if command -v openssl >/dev/null 2>&1; then
    local md; md=$(openssl md5 -binary "$f" | base64)
    [ "$md" = "$AG_MD5_EXPECTED" ] || { err "MD5 mismatch: $md ≠ $AG_MD5_EXPECTED — JANGAN install (bukan build asli)"; return 1; }
    _ag_ok "verifikasi size + MD5 cocok (build asli)"
  else
    warn "openssl tidak ada — MD5 di-skip (size OK)"
  fi
}

_ag_install() {  # [--force] [<url-atau-path-lokal>]
  local force="" custom=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force|-f|update) force=1 ;;
      http://*|https://*|file://*) custom="$1" ;;
      /*|./*|../*|~*)            custom="file://$1" ;;   # path lokal (mis. hasil aria2)
    esac
    shift
  done
  [ -n "$custom" ] && AG_URL="$custom"
  echo -e "${BOLD}🧩 Antigravity IDE — installer (build resmi linux/ARM64)${N}"
  _ag_note "Version : v$AG_VERSION"
  _ag_note "URL     : $AG_URL"
  _ag_note "Target  : $AG_DIR"
  if [ -z "$force" ] && [ -x "$AG_BIN" ] && [ -f "$AG_STAMP" ] && [ "$(head -1 "$AG_STAMP")" = "$AG_VERSION" ] && _ag_is_default_build; then
    _ag_ok "sudah terinstall (v$AG_VERSION) — '--force' utk reinstall"
    return 0
  fi
  mkdir -p "$AG_PARENT"
  local avail; avail=$(df -Pk "$AG_PARENT" 2>/dev/null | awk 'NR==2{print $4}')
  if [ -n "$avail" ] && [ "$avail" -lt 768000 ]; then
    err "disk kurang — butuh ±750MB bebas di $AG_PARENT (tersedia ${avail}KB)"; return 1
  fi
  local tmp; tmp="$(mktemp -d)"
  # file:// / path lokal → pakai langsung sumbernya (TANPA copy — hemat tmpfs,
  # penting di Termux/VM kecil). http(s) → download ke tmp.
  local blob
  case "$AG_URL" in
    file://*) blob="${AG_URL#file://}"
              [ -f "$blob" ] || { rm -rf "$tmp"; err "file tidak ada: $blob"; return 1; }
              echo -e "  ${C}▸${N} Pakai file lokal: $blob ($(du -h "$blob" | cut -f1))" ;;
    *)        blob="$tmp/ag.tar.gz"
              echo -e "  ${C}▸${N} Download ±154 MB…"
              _ag_dl "$AG_URL" "$blob" || { rm -rf "$tmp"; err "download gagal"; return 1; } ;;
  esac
  _ag_verify "$blob" || { rm -rf "$tmp"; return 1; }
  echo -e "  ${C}▸${N} Extract (±473 MB)…"
  mkdir -p "$tmp/x"
  tar xzf "$blob" -C "$tmp/x" 2>/dev/null || { rm -rf "$tmp"; err "extract gagal (file korup / ruang /tmp habis?)"; return 1; }
  if [ ! -f "$tmp/x/Antigravity-arm64/antigravity" ]; then
    rm -rf "$tmp"; err "struktur paket tak dikenali — Antigravity-arm64/ tidak ada"; return 1
  fi
  rm -rf "$AG_DIR"
