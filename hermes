# ═════════════════════════════════════════════════════════════════════════════
#  PUSH to GitHub
# ═════════════════════════════════════════════════════════════════════════════
cmd_push() {
  local dir="${1:-.}"
  local msg="${2:-update from hermes CLI v$VERSION}"
  header
  echo -e "${BOLD}📤 Push to GitHub via Hermes${N}\n"

  cd "$dir" || { err "Cannot cd to $dir"; return 1; }

  if [ ! -d ".git" ]; then
    err "Not a git repository"
    return 1
  fi

  # Ensure git identity exists for fresh Termux installs.
  if [ -z "$(git config user.name 2>/dev/null)" ]; then
    git config user.name "${GIT_AUTHOR_NAME:-$GH_USER}"
  fi
  if [ -z "$(git config user.email 2>/dev/null)" ]; then
    git config user.email "${GIT_AUTHOR_EMAIL:-${GH_USER}@users.noreply.github.com}"
  fi

  local branch repo_name origin_url
  branch="$(git branch --show-current 2>/dev/null || echo main)"
  [ -z "$branch" ] && branch="main"
  repo_name="$(basename "$(pwd)")"
  origin_url="https://github.com/${GH_USER}/${repo_name}.git"

  if ! git remote get-url origin >/dev/null 2>&1; then
    info "Adding origin: https://github.com/${GH_USER}/${repo_name}.git"
    git remote add origin "$origin_url" 2>/dev/null || true
  fi

  git add -A
  local changes
  changes=$(git status --short | wc -l | tr -d ' ')
  if [ "$changes" -eq 0 ]; then
    info "Nothing to commit"
  else
    info "$changes file(s) changed"
    git commit -m "$msg" && ok "Committed: $msg" || { err "Commit failed"; return 1; }
  fi

  info "Pushing branch: $branch"
  if [ -n "$GITHUB_PAT" ]; then
    # Push with token without storing it in .git/config or printing it.
    git push "https://x-access-token:${GITHUB_PAT}@github.com/${GH_USER}/${repo_name}.git" "HEAD:${branch}" >/dev/null 2>&1 \
      && ok "Pushed to GitHub: ${GH_USER}/${repo_name} (${branch})" \
      || { err "Push failed. Check GITHUB_PAT permissions or remote repository access."; return 1; }
  else
    git push -u origin "$branch" >/dev/null 2>&1 \
      && ok "Pushed to GitHub: ${GH_USER}/${repo_name} (${branch})" \
      || { err "Push failed. Set GITHUB_PAT with repo permissions or login to Git."; return 1; }
  fi
}

