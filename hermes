  cat << JSON
{
  "name": "Hermes Autonomous Orchestrator",
  "version": "5.11.0",
  "source": "roc-agentsroute v5.11.0 (Unified)",
  "task": "$task",
  "modes": ["autonomous", "orchestrator", "coding", "fast-response", "high-thinking", "grounding"],
  "providers": ["ais", "gateway", "gemini", "groq", "openrouter"],
