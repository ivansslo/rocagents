# ═════════════════════════════════════════════════════════════════════════════
#  AUTONOMOUS ORCHESTRATOR (High Thinking + Coding + Grounding + Fast Response)
#  Loop: Planner → Researcher → Coder → Reviewer → Tester + Grounding
# ═════════════════════════════════════════════════════════════════════════════
cmd_orchestrator() {
  local task="$*"
  [ -z "$task" ] && { err "Usage: hermes orchestrator <complex task>"; return 1; }

  header
  echo -e "${BOLD}🧠 Autonomous Orchestrator${N} — High Thinking + Grounding"
  echo -e "  Task: ${C}$task${N}"
  echo -e "  Flow: Planner → Researcher → Coder → Reviewer → Tester + Grounding"
  echo -e "  Supports: coding, fast response, high thinking, real-world tasks\n"

  local workdir="${HERMES_CODE_WORKSPACE:-$(pwd)}"
  local steps="${HERMES_ORCHESTRATOR_STEPS:-6}"
  local last=""

  for step in $(seq 1 "$steps"); do
    echo -e "${Y}── Step $step/$steps ──${N}"

    local prompt="You are Hermes Autonomous Orchestrator (high-thinking, coding, grounding).
Task: $task
Step: $step/$steps
Previous: $last

Return ONLY compact JSON:
{
  \"thought\": \"grounded reasoning\",
  \"role\": \"planner|researcher|coder|reviewer|tester\",
  \"action\": \"shell|read|write|search|done\",
  \"command\": \"...\",
  \"path\": \"...\",
  \"content\": \"...\",
  \"grounding\": \"source/logic\",
  \"message\": \"summary\"
}"

    local resp json role action thought
    resp=$(cmd_ask_internal "$prompt" "Output ONLY valid JSON.")
    json=$(printf "%s" "$resp" | _extract_json_object 2>/dev/null)

    if [ -z "$json" ]; then
      warn "Bad JSON from model"
      last="model returned invalid JSON"
      continue
    fi

    role=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("role",""))' "$json" 2>/dev/null)
    action=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("action",""))' "$json" 2>/dev/null)
    thought=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("thought",""))' "$json" 2>/dev/null)

    echo -e "  ${C}[$role]${N} $thought"

    case "$action" in
      shell)
        local cmd out
        cmd=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("command",""))' "$json" 2>/dev/null)
        echo -e "  ${BOLD}$ $cmd${N}"
        out=$(cd "$workdir" && timeout 90 bash -lc "$cmd" 2>&1 | head -60)
        printf "%s\n" "$out" | sed 's/^/    /'
        last="shell: $cmd | output: $(printf "%s" "$out" | tail -5)"
        ;;
      write)
        local p c
        p=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("path",""))' "$json" 2>/dev/null)
        c=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("content",""))' "$json" 2>/dev/null)
        mkdir -p "$(dirname "$workdir/$p")"
        printf "%s\n" "$c" > "$workdir/$p"
        ok "Wrote $p"
        last="wrote: $p"
        ;;
      done)
        local msg
        msg=$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("message","Complete"))' "$json" 2>/dev/null)
        ok "$msg"
        return 0
        ;;
      *)
        echo -e "  ${D}$action${N}"
        last="$action"
        ;;
    esac
    echo ""
  done
  warn "Max steps reached. Continue manually with: hermes coding  (or /agent inside chat)"
}

